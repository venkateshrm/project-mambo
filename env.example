<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Project Mambo Dashboard</title><style>
:root{--bg:#090909;--card:#171717;--muted:#999;--text:#f7f7f7;--accent:#ff6b00;--border:rgba(255,255,255,.1);--green:#22c55e;--red:#ef4444}*{box-sizing:border-box}body{margin:0;font-family:Inter,Segoe UI,system-ui,sans-serif;background:var(--bg);color:var(--text)}.wrap{max-width:1100px;margin:auto;padding:20px}.top{display:flex;justify-content:space-between;gap:12px;align-items:center}.card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:18px;margin:14px 0}input,select,textarea{width:100%;padding:12px;background:#101010;color:#fff;border:1px solid var(--border);border-radius:10px;margin:6px 0}.btn{padding:11px 14px;border:0;border-radius:12px;background:var(--accent);color:white;font-weight:800;cursor:pointer}.ghost{background:#242424}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.list{display:grid;gap:10px}.item{background:#111;border:1px solid var(--border);padding:12px;border-radius:12px}.muted{color:var(--muted);font-size:13px}.hidden{display:none}a{color:var(--accent)}@media(max-width:800px){.grid{grid-template-columns:1fr}.top{align-items:flex-start;flex-direction:column}}
</style></head><body><div class="wrap"><div class="top"><div><h1>Project Mambo Dashboard</h1><div class="muted">Production backend · Login · Vehicles · Repairs · Docs · Leads</div></div><div><button class="btn ghost" onclick="logout()">Logout</button></div></div>
<div id="auth" class="card"><h2>Owner Login</h2><div class="grid"><div><h3>Login</h3><input id="loginEmail" placeholder="Email"><input id="loginPassword" type="password" placeholder="Password"><button class="btn" onclick="login()">Login</button></div><div><h3>Register first owner</h3><input id="regName" placeholder="Full name"><input id="regEmail" placeholder="Email"><input id="regPassword" type="password" placeholder="Password"><button class="btn" onclick="register()">Register</button></div></div><p class="muted">After login, click Seed Mambo to create your KTM Adventure 390 record.</p></div>
<div id="app" class="hidden"><div class="card"><button class="btn" onclick="seedMambo()">Seed Mambo Vehicle</button> <button class="btn ghost" onclick="loadVehicles()">Refresh</button><div id="vehicles" class="list"></div></div><div id="vehiclePanel" class="hidden"><div class="card"><h2 id="vtitle"></h2><p id="vmeta" class="muted"></p><p><a id="publicReport" target="_blank">Open public buyer report</a></p></div><div class="grid"><div class="card"><h3>Add Repair</h3><input id="rTitle" placeholder="Repair title"><input id="rSystem" placeholder="System: engine/suspension/brakes"><select id="rStatus"><option value="pending">pending</option><option value="wip">wip</option><option value="done">done</option></select><input id="rCost" type="number" placeholder="Cost"><textarea id="rNotes" placeholder="Notes"></textarea><button class="btn" onclick="addRepair()">Add Repair</button></div><div class="card"><h3>Add Lead</h3><input id="lName" placeholder="Buyer name"><input id="lPhone" placeholder="Phone"><select id="lStage"><option value="hot">hot</option><option value="warm">warm</option><option value="cold">cold</option><option value="closed">closed</option></select><input id="lBudget" type="number" placeholder="Budget"><textarea id="lNotes" placeholder="Notes"></textarea><button class="btn" onclick="addLead()">Add Lead</button></div></div><div class="card"><h3>Upload Document</h3><input id="dTitle" placeholder="Document title"><select id="dType"><option>inspection</option><option>bill</option><option>before_photo</option><option>after_photo</option><option>test_ride</option></select><input id="dFile" type="file"><button class="btn" onclick="uploadDoc()">Upload</button></div><div class="grid"><div class="card"><h3>Repairs</h3><div id="repairs" class="list"></div></div><div class="card"><h3>Documents</h3><div id="docs" class="list"></div></div></div><div class="card"><h3>Leads</h3><div id="leads" class="list"></div></div></div></div></div><script>
let token=localStorage.getItem('mambo_token')||'';let currentVehicle=null;function headers(){return {'Content-Type':'application/json','Authorization':'Bearer '+token}}function showApp(){document.getElementById('auth').classList.toggle('hidden',!!token);document.getElementById('app').classList.toggle('hidden',!token);if(token)loadVehicles()}async function register(){let res=await fetch('/auth/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({full_name:regName.value,email:regEmail.value,password:regPassword.value})});alert(res.ok?'Registered. Now login.':await res.text())}async function login(){let form=new URLSearchParams();form.append('username',loginEmail.value);form.append('password',loginPassword.value);let res=await fetch('/auth/token',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:form});let data=await res.json();if(data.access_token){token=data.access_token;localStorage.setItem('mambo_token',token);showApp()}else alert(JSON.stringify(data))}function logout(){localStorage.removeItem('mambo_token');token='';location.reload()}async function seedMambo(){await fetch('/api/seed-mambo',{method:'POST',headers:headers()});loadVehicles()}async function loadVehicles(){let res=await fetch('/api/vehicles',{headers:headers()});let data=await res.json();vehicles.innerHTML=data.map(v=>`<div class="item"><b>${v.name}</b><div class="muted">${v.model} · ${v.registration||''}</div><button class="btn ghost" onclick="selectVehicle(${v.id})">Open</button></div>`).join('')}async function selectVehicle(id){let res=await fetch('/api/vehicles/'+id,{headers:headers()});currentVehicle=await res.json();vehiclePanel.classList.remove('hidden');vtitle.textContent=currentVehicle.name;vmeta.textContent=currentVehicle.model+' · '+(currentVehicle.registration||'');publicReport.href='/report/'+currentVehicle.slug;renderVehicle()}function renderVehicle(){repairs.innerHTML=currentVehicle.repairs.map(r=>`<div class="item"><b>${r.title}</b><div class="muted">${r.system} · ${r.status} · ₹${r.cost}</div><p>${r.notes||''}</p></div>`).join('')||'<p class="muted">No repairs</p>';docs.innerHTML=currentVehicle.documents.map(d=>`<div class="item"><b>${d.title}</b><div class="muted">${d.doc_type}</div><a href="${d.file_url}" target="_blank">Open file</a></div>`).join('')||'<p class="muted">No documents</p>';leads.innerHTML=currentVehicle.leads.map(l=>`<div class="item"><b>${l.name}</b><div class="muted">${l.phone||''} · ${l.stage} · ₹${l.budget||0}</div><p>${l.notes||''}</p></div>`).join('')||'<p class="muted">No leads</p>'}async function addRepair(){await fetch(`/api/vehicles/${currentVehicle.id}/repairs`,{method:'POST',headers:headers(),body:JSON.stringify({title:rTitle.value,system:rSystem.value,status:rStatus.value,cost:Number(rCost.value||0),notes:rNotes.value})});selectVehicle(currentVehicle.id)}async function addLead(){await fetch(`/api/vehicles/${currentVehicle.id}/leads`,{method:'POST',headers:headers(),body:JSON.stringify({name:lName.value,phone:lPhone.value,stage:lStage.value,budget:Number(lBudget.value||0),notes:lNotes.value})});selectVehicle(currentVehicle.id)}async function uploadDoc(){let fd=new FormData();fd.append('title',dTitle.value);fd.append('doc_type',dType.value);fd.append('file',dFile.files[0]);let res=await fetch(`/api/vehicles/${currentVehicle.id}/documents`,{method:'POST',headers:{'Authorization':'Bearer '+token},body:fd});if(!res.ok)alert(await res.text());selectVehicle(currentVehicle.id)}showApp();
</script></body></html>
